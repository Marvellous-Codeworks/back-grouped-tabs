{
  "manifest_version": 3,
  "name": "Back All Grouped Tabs",
  "version": "1.2",
  "description": "Sends history.back() to all tabs belonging to a tab group, leaving ungrouped tabs untouched.",
  "author": "Marvellous Codeworks",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["tabs", "tabGroups"],
  "action": {
    "default_title": "Back on all grouped tabs",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
